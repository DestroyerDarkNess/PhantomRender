<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework> <!-- Must be single target for Native AOT -->
    <PublishAot>true</PublishAot>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <Platforms>x64;x86</Platforms>
    <OutputType>Library</OutputType> <!-- Or Exe depending on loader, but Library for strict DLL export -->
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <AutoPublishOnBuild Condition="'$(AutoPublishOnBuild)' == ''">true</AutoPublishOnBuild>
  </PropertyGroup>

  <PropertyGroup>
    <_AutoPublishRuntimeIdentifier Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)</_AutoPublishRuntimeIdentifier>
    <_AutoPublishRuntimeIdentifier Condition="'$(_AutoPublishRuntimeIdentifier)' == '' and '$(Platform)' == 'x86'">win-x86</_AutoPublishRuntimeIdentifier>
    <_AutoPublishRuntimeIdentifier Condition="'$(_AutoPublishRuntimeIdentifier)' == ''">win-x64</_AutoPublishRuntimeIdentifier>
    <_AutoPublishDir>$(MSBuildProjectDirectory)\bin\$(Configuration)\publish\$(_AutoPublishRuntimeIdentifier)\</_AutoPublishDir>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PhantomRender\PhantomRender.csproj" />
    <ProjectReference Include="..\PhantomRender.ImGui\PhantomRender.ImGui.csproj" />
  </ItemGroup>

  <ItemGroup>
    <RdXmlFile Include="rd.xml" />
    <PackageReference Include="MinHook.NET" Version="1.1.2" /> <!-- Ensure explicit ref here too for trimming/rd -->
    <PackageReference Include="Hexa.NET.ImGui" Version="2.2.9" />
    <PackageReference Include="Hexa.NET.ImGui.Backends" Version="1.0.18" />
    <PackageReference Include="HexaGen.Runtime" Version="1.1.24" />
  </ItemGroup>

  <Target Name="AutoPublishAfterBuild"
          AfterTargets="Build"
          Condition="'$(AutoPublishOnBuild)' == 'true'
                   and '$(DesignTimeBuild)' != 'true'
                   and '$(IsCrossTargetingBuild)' != 'true'
                   and '$(SkipAutoPublish)' != 'true'">
    <Message Importance="High"
             Text="Auto-publishing $(MSBuildProjectName) ($(Configuration), $(_AutoPublishRuntimeIdentifier)) to $(_AutoPublishDir)" />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Publish"
             Properties="Configuration=$(Configuration);RuntimeIdentifier=$(_AutoPublishRuntimeIdentifier);SelfContained=true;PublishDir=$(_AutoPublishDir);SkipAutoPublish=true" />
  </Target>

</Project>
